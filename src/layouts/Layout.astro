---
import ChatWidget from "../components/ChatWidget.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

export interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Maingoo - Gestión inteligente de restaurantes con IA",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/maingoo_logo.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-H6FCBZSDLH"
    ></script>
    <script is:inline define:vars={{ GA_ID: "G-H6FCBZSDLH" }}>
      // Extend Window interface to include dataLayer
      window.dataLayer = window.dataLayer || [];

      // Define gtag function
      function gtag() {
        window.dataLayer.push(arguments);
      }

      // Initialize gtag
      gtag.call(window, "js", new Date());
      gtag.call(window, "config", GA_ID);
    </script>
    <!-- End Google Analytics -->

    <!-- Microsoft Clarity Analytics -->
    <script type="text/javascript">
      (function (c, l, a, r, i, t, y) {
        c[a] =
          c[a] ||
          function () {
            (c[a].q = c[a].q || []).push(arguments);
          };
        t = l.createElement(r);
        t.async = 1;
        t.src = "https://www.clarity.ms/tag/" + i;
        y = l.getElementsByTagName(r)[0];
        y.parentNode.insertBefore(t, y);
      })(window, document, "clarity", "script", "tc3gljr35e");
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <!-- Cookie Script -->
    <script
      type="text/javascript"
      charset="UTF-8"
      src="//cdn.cookie-script.com/s/cec8a2c75a9cad8b24709d83c765d8fd.js"
    ></script>
    <!-- Google reCAPTCHA v2 -->
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
    <!-- Dark mode script to prevent FOUC -->
    <script is:inline>
      // Check for saved theme preference or default to system preference
      (function () {
        console.log("=== FOUC Prevention Script ===");

        const savedTheme = localStorage.getItem("darkMode");
        const systemPreference = window.matchMedia(
          "(prefers-color-scheme: dark)"
        ).matches;

        console.log("FOUC - Saved theme:", savedTheme);
        console.log("FOUC - System preference (dark):", systemPreference);
        console.log(
          "FOUC - System preference (light):",
          window.matchMedia("(prefers-color-scheme: light)").matches
        );

        let shouldBeDark = false;

        if (savedTheme !== null) {
          // User has a saved preference
          shouldBeDark = savedTheme === "true";
          console.log("FOUC - Using saved preference:", shouldBeDark);
        } else {
          // No saved preference, follow system
          shouldBeDark = systemPreference;
          console.log("FOUC - Using system preference:", shouldBeDark);
        }

        console.log("FOUC - Final decision:", shouldBeDark);

        if (shouldBeDark) {
          document.documentElement.classList.add("dark");
          console.log("FOUC - Added dark class");
        } else {
          document.documentElement.classList.remove("dark");
          console.log("FOUC - Removed dark class (if it existed)");
        }

        console.log(
          "FOUC - Final HTML classes:",
          document.documentElement.className
        );
        console.log("===============================");
      })();
    </script>

    <script>
      // Declarar el tipo de window.chatWidget
      declare global {
        interface Window {
          chatWidget: any;
        }
      }

      function openChat() {
        const chatWindow = document.getElementById("chat-window");
        if (chatWindow) {
          chatWindow.style.transform = "scale(1)";
          chatWindow.style.opacity = "1";

          const chatInput = document.getElementById("chat-input");
          if (chatInput) {
            setTimeout(() => chatInput.focus(), 300);
          }
        }
      }

      // Agregar el evento de clic
      document.querySelectorAll("#open-chat")?.forEach(element => {
        element.addEventListener("click", (e) => {
          e.preventDefault();
          openChat();
        });
      });
    </script>
  </head>
  <body
    class="relative font-inter antialiased dark:bg-[#F0F7F4] dark:text-[#1A3C34] transition-colors duration-300 dark-mode-transition overflow-x-hidden"
  >
    <!-- Background Effects -->
    <div class="fixed inset-0 overflow-hidden pointer-events-none z-0">
      <div class="absolute -top-[100px] -left-[100px] w-[600px] h-[600px] bg-[#8BC4AD] rounded-full mix-blend-multiply filter blur-[120px] opacity-40 animate-pulse"></div>
      <div class="absolute top-[20%] -right-[100px] w-[500px] h-[500px] bg-[#6B9E86] rounded-full mix-blend-multiply filter blur-[120px] opacity-35"></div>
      <div class="absolute bottom-[10%] left-[20%] w-[400px] h-[400px] bg-[#A5D4BF] rounded-full mix-blend-multiply filter blur-[120px] opacity-25"></div>
      <div class="absolute top-[60%] right-[15%] w-[450px] h-[450px] bg-[#7BAF96] rounded-full mix-blend-multiply filter blur-[120px] opacity-30"></div>
    </div>
    <!-- Content -->
    <div class="relative z-10">
      <Header />
      <slot />
      <Footer />
    </div>

    <!-- Chat Widget Component -->
    <ChatWidget />

    <style>
      html {
        font-family: "Inter", system-ui, sans-serif;
      }
    </style>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
