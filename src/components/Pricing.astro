---

---

<section id="pricing" class="pt-16 pb-1">
  <div class="container mx-auto px-6">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-5xl font-bold dark:text-[#1A3C34] mb-6">
        Únete a la beta de
        <span class="text-[#6B9E86]"> Maingoo </span>
      </h2>
      <p class="text-xl dark:text-[#1A3C34]">
        Acceso temprano gratuito para restaurantes innovadores que quieren ser
        parte de nuestra (r)evolución.
      </p>
    </div>

    <!-- Beta Access Cards -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 max-w-6xl mx-auto mb-16">
      <!-- Beta Early Access -->
      <div
        class="dark:bg-[#FFFFFF] border-2 border-[#6B9E86] rounded-2xl p-8 hover:shadow-xl transition-all relative"
      >
        <div class="absolute -top-4 left-1/2 transform -translate-x-1/2">
          <div
            class="bg-[#F0F7F4] border-2 border-[#6B9E86] text-[#000000] px-6 py-2 rounded-full text-sm font-semibold whitespace-nowrap"
          >
            Disponible Ahora
          </div>
        </div>

        <div class="text-center mb-8">
          <h3 class="text-xl font-bold dark:text-[#000000] mb-2">
            Beta Early Access
          </h3>
          <p class="text-lg dark:text-[#000000] mb-6">
            ¡Acceso anticipado gratuito!
          </p>
          <div class="mb-6">
            <span class="text-4xl font-bold text-[#000000]">Gratis</span>
            <span class="dark:text-[#000000]"> durante la beta</span>
          </div>
          <a
            href="#contact"
            class="block w-full border-2 border-[#000000] bg-[#F0F7F4] text-[#1A3C34] py-3 px-6 rounded-lg font-semibold hover:shadow-lg transition-all text-center"
          >
            Solicitar Acceso a la Beta
          </a>
        </div>

        <div class="space-y-4">
          <div class="flex items-center space-x-3">
            <div
              class="w-5 h-5 rounded-full bg-[#F0F7F4] border border-[#000000]"
            >
            </div>
            <span class="dark:text-[#000000] relative inline-block">
              Procesado de factura instantaneo
            </span>
          </div>
          <div class="flex items-center space-x-3">
            <div
              class="w-5 h-5 rounded-full bg-[#F0F7F4] border border-[#000000]"
            >
            </div>
            <span class="dark:text-[#000000]">Panel de control y analítcas</span
            >
          </div>
          <div class="flex items-center space-x-3">
            <div
              class="w-5 h-5 rounded-full bg-[#F0F7F4] border border-[#000000]"
            >
            </div>
            <span class="dark:text-[#000000]">Gestión de proveedores</span>
          </div>
          <div class="flex items-center space-x-3">
            <div
              class="w-5 h-5 rounded-full bg-[#F0F7F4] border border-[#000000]"
            >
            </div>
            <span class="dark:text-[#000000]">Control de inventario</span>
          </div>
          <div class="flex items-center space-x-3">
            <div
              class="w-5 h-5 rounded-full bg-[#F0F7F4] border border-[#000000]"
            >
            </div>
            <span class="dark:text-[#000000]">Soporte técnico</span>
          </div>
        </div>
      </div>

      <!-- Professional Plan - Coming Soon -->
      <div
        class="dark:bg-gray-800  border-2 border-[#6B9E86] rounded-2xl p-8 hover:shadow-xl transition-all relative opacity-75"
      >
        <div class="absolute -top-4 left-1/2 transform -translate-x-1/2">
          <div
            class="bg-gray-500 text-white px-6 py-2 rounded-full text-sm font-semibold border-2 border-[#6B9E86]"
          >
            Próximamente
          </div>
        </div>

        <div class="text-center mb-8">
          <h3 class="text-xl font-bold dark:text-white mb-2 ">
            Plan Profesional
          </h3>
          <p class="dark:text-gray-300 mb-6">Todo lo de la Beta mas:</p>
          <div class="mb-6">
            <span class="text-4xl font-bold text-gray-400">Locked</span>
          </div>
        </div>

        <div class="space-y-4">
          <div class="flex items-center space-x-3">
            <div
              class="w-5 h-5 rounded-full bg-gray-400 border border-[#1A3C34]"
            >
            </div>
            <span class="dark:text-gray-400">Analítica impulsada por IA</span>
          </div>
          <div class="flex items-center space-x-3">
            <div
              class="w-5 h-5 rounded-full bg-gray-400 border border-[#1A3C34]"
            >
            </div>
            <span class="dark:text-gray-400">Administración y finanzas</span>
          </div>
          <div class="flex items-center space-x-3">
            <div
              class="w-5 h-5 rounded-full bg-gray-400 border border-[#1A3C34]"
            >
            </div>
            <span class="dark:text-gray-400">Documentación y APPCC</span>
          </div>
          <div class="flex items-center space-x-3">
            <div
              class="w-5 h-5 rounded-full bg-gray-400 border border-[#1A3C34]"
            >
            </div>
            <span class="dark:text-gray-400">Recetas y escandallos</span>
          </div>
          <div class="flex items-center space-x-3">
            <div
              class="w-5 h-5 rounded-full bg-gray-400 border border-[#1A3C34]"
            >
            </div>
            <span class="dark:text-gray-400">TPV y comandas</span>
          </div>
          <div class="flex items-center space-x-3">
            <div
              class="w-5 h-5 rounded-full bg-gray-400 border border-[#1A3C34]"
            >
            </div>
            <span class="dark:text-gray-400">Gestión de RRHH</span>
          </div>
          <div class="flex items-center space-x-3">
            <div
              class="w-5 h-5 rounded-full bg-gray-400 border border-[#1A3C34]"
            >
            </div>
            <span class="dark:text-gray-400">Y mucho mas por venir!</span>
          </div>
        </div>
      </div>

      <!-- Enterprise Plan - Coming Soon -->
      <div
        class="bg-gray-100 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-2xl p-8 hover:shadow-xl transition-all relative opacity-75"
      >
        <div class="absolute -top-4 left-1/2 transform -translate-x-1/2">
          <div
            class="bg-gray-500 text-white px-6 py-2 rounded-full text-sm font-semibold"
          >
            Próximamente
          </div>
        </div>

        <div class="text-center mb-8">
          <h3 class="text-xl font-bold dark:text-white mb-2">
            Plan Empresarial
          </h3>
          <p class="dark:text-gray-300 mb-6">Para grandes operaciones</p>
          <div class="mb-6">
            <span class="text-4xl font-bold text-gray-400">Locked</span>
          </div>
        </div>

        <div class="space-y-4">
          <div class="flex items-center space-x-3">
            <div
              class="w-5 h-5 rounded-full bg-gray-400 border border-[#1A3C34]"
            >
            </div>
            <span class="dark:text-gray-400">Multi-sede</span>
          </div>
          <div class="flex items-center space-x-3">
            <div
              class="w-5 h-5 rounded-full bg-gray-400 border border-[#1A3C34]"
            >
            </div>
            <span class="dark:text-gray-400">Usuarios ilimitados</span>
          </div>
          <div class="mt-6 pt-12 border-t border-gray-600">
            <span class="dark:text-gray-400"
              >Precio único y para siempre en el plan profesional y
              empresarial, con acceso total a todas las funciones actuales y a
              todas las futuras.</span
            >
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.getElementById("open-chat-faq")?.addEventListener("click", (e) => {
      e.preventDefault();
      const chatWindow = document.getElementById("chat-window");
      if (chatWindow) {
        chatWindow.style.transform = "scale(1)";
        chatWindow.style.opacity = "1";

        const chatInput = document.getElementById("chat-input");
        if (chatInput) {
          setTimeout(() => chatInput.focus(), 300);
        }
      }
    });
  </script>
</section>
