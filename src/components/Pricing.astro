      <!-- Enterprise Plan - Coming Soon -->
      <div
        class="bg-gradient-to-b from-gray-800 to-[#0f2820] rounded-2xl p-8 hover:shadow-xl transition-all relative flex flex-col h-full"
      >
        <div class="absolute -top-4 left-1/2 transform -translate-x-1/2 z-10">
          <div
            class="bg-gray-600 text-white px-6 py-2 rounded-full text-sm font-semibold shadow-lg"
          >
            Próximamente
          </div>
        </div>

