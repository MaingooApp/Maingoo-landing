                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span class="text-[#000000] font-bold"
              >Sin compromiso de permanencia</span
            >
          </div>
        </div>
      </div>

      <!-- Professional Plan - Coming Soon -->
      <div
        class="bg-gradient-to-b from-gray-800 to-[#0f2820] rounded-2xl p-8 hover:shadow-xl transition-all relative flex flex-col h-full"
