<section id="pricing" class="pt-16 pb-1">
  <div class="container mx-auto px-6">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-5xl font-bold dark:text-[#1A3C34] mb-6">
        Únete a la beta de
        <span class="text-[#6B9E86]"> Maingoo </span>
      </h2>
      <p class="text-xl dark:text-[#1A3C34]">
        Acceso temprano gratuito para restaurantes innovadores que quieren ser
        parte de nuestra (r)evolución.
      </p>
    </div>

    <!-- Beta Access Cards -->
    <div
      class="grid grid-cols-1 lg:grid-cols-3 gap-8 max-w-6xl mx-auto mb-16 items-stretch"
    >
      <!-- Beta Early Access -->
      <div
        class="bg-white border border-[#6B9E86] rounded-2xl p-8 shadow-xl shadow-[#6B9E86]/10 hover:shadow-2xl transition-all relative flex flex-col h-full"
      >
        <div class="absolute -top-4 left-1/2 transform -translate-x-1/2">
          <div
            class="bg-[#6B9E86] text-white px-6 py-2 rounded-full text-sm font-semibold whitespace-nowrap"
          >
            Disponible Ahora
          </div>
        </div>

        <div class="text-center mb-8">
          <h3 class="text-xl font-bold text-[#000000] mb-2">
            Beta Early Access
          </h3>
          <p class="text-lg text-[#000000] mb-6">
            ¡Acceso anticipado gratuito!
          </p>
          <div class="mb-6">
            <span class="text-4xl font-bold text-[#000000]">Gratis</span>
            <span class="text-[#000000]"> durante la beta</span>
          </div>
          <a
            href="#contact"
            class="block w-full bg-[#6B9E86] hover:bg-[#5a8a71] text-white py-3 px-6 rounded-lg font-semibold hover:shadow-lg transition-all text-center"
          >
            Solicitar Acceso a la Beta
          </a>
        </div>

        <div class="space-y-4 flex-grow">
          <div class="flex items-center space-x-3">
            <svg
              class="w-5 h-5 text-[#6B9E86] flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span class="text-[#000000]">
              Procesado de factura instantaneo
            </span>
          </div>
          <div class="flex items-center space-x-3">
            <svg
              class="w-5 h-5 text-[#6B9E86] flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span class="text-[#000000]">Panel de control y analíticas</span>
          </div>
          <div class="flex items-center space-x-3">
            <svg
              class="w-5 h-5 text-[#6B9E86] flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span class="text-[#000000]">Gestión de proveedores</span>
          </div>
          <div class="flex items-center space-x-3">
            <svg
              class="w-5 h-5 text-[#6B9E86] flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
