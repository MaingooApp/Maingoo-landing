                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span class="text-[#000000]">Control de inventario</span>
          </div>
          <div class="flex items-center space-x-3">
            <svg
              class="w-5 h-5 text-[#6B9E86] flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span class="text-[#000000]">Soporte técnico</span>
          </div>
          <div class="flex items-center space-x-3">
            <svg
              class="w-5 h-5 text-[#6B9E86] flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
