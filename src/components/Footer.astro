<style>
  @media (max-width: 768px) {
    .text-center-flex {
      justify-content: center;
    }
    .text-center {
      text-align: center;
    }
  }
</style>

<footer class="dark:bg-[hsl(166,40%,9%)] text-[#F0F7F4]">
  <div class="container mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Company Info -->
      <div class="md:col-span-1">
        <div class="flex items-center justify-center md:justify-start space-x-2 mb-6">
          <img src="/maingoo_logo.svg" alt="Maingoo Logo" class="w-8 h-8" />
          <span class="text-xl font-bold">Maingoo</span>
        </div>
        <p
          class=" dark:text-[#F0F7F4] mb-6 leading-relaxed text-center"
        >
          (R)evolucionando la gestión de restaurantes con inteligencia
          artificial.
        </p>
      </div>

      <!-- Product Links -->
      <div class="text-center">
        <h3 class="text-lg font-semibold mb-6">Producto</h3>
        <ul class="space-y-3">
          <li>
            <a
              href="/#features"
              class="text-[16px] font-normal dark:text-[#F0F7F4] transition-colors whitespace-nowrap"
              style="--hover-color: #6B9E86;"
              onmouseover="this.style.color='#6B9E86'"
              onmouseout="this.style.color=''"
              >Características</a
            >
          </li>
          <li>
            <a
              href="/#pricing"
              class="text-[16px] font-normal dark:text-[#F0F7F4] transition-colors whitespace-nowrap"
              style="--hover-color: #6B9E86;"
              onmouseover="this.style.color='#6B9E86'"
              onmouseout="this.style.color=''"
              >Precios</a
            >
          </li>
          <li>
            <a
              href="#contact"
              class="text-[16px] font-normal dark:text-[#F0F7F4] transition-colors whitespace-nowrap"
              style="--hover-color: #6B9E86;"
              onmouseover="this.style.color='#6B9E86'"
              onmouseout="this.style.color=''"
              >Acceso a la Beta</a
            >
          </li>
        </ul>
      </div>

      <!-- Company Links -->
      <div class="text-center">
        <h3 class="text-lg font-semibold mb-6">Empresa</h3>
        <ul class="space-y-3">
          <li>
            <a
              href="javascript:console.log('Próximamente: Página corporativa de Maingoo')"
              class="text-[16px] font-normal dark:text-[#F0F7F4] transition-colors whitespace-nowrap"
              style="--hover-color: #6B9E86;"
              onmouseover="this.style.color='#6B9E86'"
              onmouseout="this.style.color=''"
              >Acerca de</a
            >
          </li>
          <li>
            <a
              href="javascript:console.log('Próximamente: Sala de prensa Maingoo')"
              class="text-[16px] font-normal dark:text-[#F0F7F4] transition-colors whitespace-nowrap"
              style="--hover-color: #6B9E86;"
              onmouseover="this.style.color='#6B9E86'"
              onmouseout="this.style.color=''"
              >Prensa</a
            >
          </li>
        </ul>
      </div>

      <!-- Support Links -->
      <div class="text-center">
        <h3 class="text-lg font-semibold mb-6">Soporte</h3>
        <ul class="space-y-3">
          <li>
            <a
              href="javascript:console.log('Próximamente: Centro de seguridad y cumplimiento')"
              class="text-[16px] font-normal dark:text-[#F0F7F4] transition-colors whitespace-nowrap"
              style="--hover-color: #6B9E86;"
              onmouseover="this.style.color='#6B9E86'"
              onmouseout="this.style.color=''"
              >Seguridad</a
            >
          </li>
          <li>
            <a
              href="#contact"
              class="text-[16px] font-normal dark:text-[#F0F7F4] transition-colors whitespace-nowrap"
              style="--hover-color: #6B9E86;"
              onmouseover="this.style.color='#6B9E86'"
              onmouseout="this.style.color=''"
              >Contacto</a
            >
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Section -->
    <div class="border-t dark:border-gray-700 mt-12 pt-8">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <p class=" dark:text-[#F0F7F4] text-sm">
          © 2025 Maingoo. Todos los derechos reservados.
        </p>
        <div class="flex space-x-6 mt-4 md:mt-0">
          <a  
            href="politica-privacidad" 
            class="text-[16px] font-normal dark:text-[#F0F7F4] transition-colors whitespace-nowrap"
            style="--hover-color: #6B9E86;"
            onmouseover="this.style.color='#6B9E86'"
            onmouseout="this.style.color=''"
            >
            Política de Privacidad
          </a>
          <a 
            href="terminos-servicio" 
            class="text-[16px] font-normal dark:text-[#F0F7F4] transition-colors whitespace-nowrap"
            style="--hover-color: #6B9E86;"
            onmouseover="this.style.color='#6B9E86'"
            onmouseout="this.style.color=''"
            >
            Términos de Servicio
          </a>
          <a 
            href="cookies" 
            class="text-[16px] font-normal dark:text-[#F0F7F4] transition-colors whitespace-nowrap"
            style="--hover-color: #6B9E86;"
            onmouseover="this.style.color='#6B9E86'"
            onmouseout="this.style.color=''"
            >
            Cookies
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
