<section class="relative pt-16 pb-16 min-h-[90vh] bg-cover bg-center z-20" style="background-image: url('/Hero-bg.png');">
  <!-- Degradado overlay superior -->
  <div class="absolute inset-0 z-10" style="background: linear-gradient(to bottom, #6B9E86 0%, #6B9E86 25%, transparent 55%);"></div>
  
  <!-- Bloque sólido inferior con curva cóncava superior -->
  <div class="absolute bottom-0 left-0 right-0 h-[35%] z-10 bg-[#6B9E86]" style="clip-path: ellipse(60% 40% at 50% 90%);"></div>
  
  <div class="container mx-auto px-6 h-full relative z-20">
    <div
      class="max-w-4xl mx-auto text-left h-full flex flex-col justify-center"
    >
      <!-- Hero Headline -->
      <style>
        /* Estilos compartidos */
        .headline-row {
          width: 100%;
        }

        .flex-custom {
          display: flex !important;
          justify-content: flex-start;
          align-items: baseline;
          gap: 10px;
        }

        .changing-business::after {
          content: "Restaurante";
          animation: changeWord 34s infinite;
          font-weight: bold;
          white-space: nowrap;
        }

        /* Estilos para Desktop */
        @media (min-width: 769px) {
          .headline-row {
            display: flex;
            align-items: center;
            justify-content: flex-start;
            margin-bottom: 0.25em;
          }
          .headline-row:last-child {
            margin-bottom: 0;
          }
          .fixed-text {
            text-align: left;
            white-space: nowrap;
          }
          .changing-container {
            width: auto;
            min-width: 300px;
            text-align: left;
            margin-left: 1rem;
            position: relative;
          }
          .changing-business {
            position: relative;
            display: block;
            height: 1em;
          }
          .changing-business::after {
            color: #000000;
            position: absolute;
            left: 0;
          }

          :global(.dark) .changing-business::after {
            color: #000000;
          }
        }

        /* Estilos para Móvil */
        @media (max-width: 768px) {
          .fixed-text {
            padding-left: 8px;
          }
          .headline-row {
            display: block;
            text-align: left;
          }
          .headline-row:last-child {
            margin-bottom: 0;
          }

          .changing-container {
            display: block;
            margin-top: 0.2em;
            min-height: 1.2em;
            min-width: 177px;
            text-align: left;
          }
          .changing-business {
            display: block;
            height: 1.2em;
          }
          .changing-business::after {
            color: #000000;
            position: relative;
            display: inline-block;
          }

          :global(.dark) .changing-business::after {
            color: #000000;
          }
        }

        @keyframes changeWord {
          0%,
          5.88% {
            content: "Buffet";
          }
          5.89%,
          11.76% {
            content: "Cocktelería";
          }
          11.77%,
          17.64% {
            content: "Cafetería";
          }
          17.65%,
          23.52% {
            content: "Restaurante";
          }
          23.53%,
          29.41% {
            content: "Catering";
          }
          29.42%,
          35.29% {
            content: "Cervecería";
          }
          35.30%,
          41.17% {
            content: "Foodtruck";
          }
          41.18%,
          47.05% {
            content: "Chiringuito";
          }
          47.06%,
          52.94% {
            content: "Cocktelería";
          }
          52.95%,
          58.82% {
            content: "Churrería";
          }
          58.83%,
          64.70% {
            content: "Restaurante";
          }
          64.71%,
          70.58% {
            content: "Heladería";
          }
          70.59%,
          76.47% {
            content: "Foodtruck";
          }
          76.48%,
          82.35% {
            content: "Panadería";
          }
          82.36%,
          88.23% {
            content: "Pastelería";
          }
          88.24%,
          94.11% {
            content: "Pizzería";
          }
          94.12%,
          100% {
            content: "Sidrería";
          }
        }
      </style>
      <h1
        class="text-3xl sm:text-4xl md:text-6xl font-bold mb-8"
        style="color: #FFFFFF;"
      >
        <div class="headline-row flex-custom">
          <div class="fixed-text">
            <span style="color: #FFFFFF;">Gestiona tu</span>
          </div>
          <div class="changing-container">
            <span class="changing-business"></span>
          </div>
        </div>
        <div class="headline-row" style="display: flex; align-items: baseline; gap: 0.5rem; flex-wrap: nowrap;">
          <span style="color: #FFFFFF;">con Inteligencia Artificial</span>
        </div>
      </h1>

      <style>
        @media (min-width: 640px) {
          .ia-text {
            font-size: 3rem !important;
          }
        }
        @media (min-width: 768px) {
          .ia-text {
            font-size: 4rem !important;
          }
        }
      </style>

      <!-- Hero Subtitle -->
      <p
        class="text-xl md:text-2xl mb-8 leading-relaxed"
        style="color: #FFFFFF;"
      >
        Maingoo (r)evoluciona la gestión con automatización inteligente de
        facturas, inventario y análisis de datos para optimizar tu negocio.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
        <a
          href="#contact"
          class="bg-[#6B9E86] text-[#FFFFFF] px-8 py-4 rounded-lg text-lg font-semibold hover:shadow-xl transition-all transform hover:-translate-y-1 inline-block text-center"
        >
          Solicitar Acceso a la Beta
        </a>
        <button
          id="open-chat"
          class="relative bg-transparent text-[#] px-8 py-4 rounded-lg text-lg font-semibold hover:shadow-xl transition-all transform hover:-translate-y-1 inline-flex items-center justify-between gap-4"
          style="border: 3px solid #6B9E86; background: rgba(240, 247, 244, 0.15); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);"
        >
        <span>Pregunta a Maingoo</span>
        <img src="/maingoo_logo.svg" alt="IA" class="w-7 h-7" />
      </button>
      </div>

      <!-- Hero Stats -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <!-- Card 1: Ahorra horas -->
        <div class="bg-[#FFFFFF] rounded-xl p-6 shadow-lg">
          <div class="flex justify-center mb-4">
            <svg
              class="w-12 h-12 text-[#6B9E86]"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-[#1A3C34] mb-3 text-center">
            Ahorra horas de trabajo a la semana
          </h3>
          <p class="text-[#1A3C34] text-center text-sm">
            Automatiza tareas repetitivas y dedica más tiempo a hacer crecer tu negocio.
          </p>
        </div>

        <!-- Card 2: Diseñado junto a gerentes reales -->
        <div class="bg-[#FFFFFF] rounded-xl p-6 shadow-lg">
          <div class="flex justify-center mb-4">
            <svg
              class="w-12 h-12 text-[#6B9E86]"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-[#1A3C34] mb-3 text-center">
            Diseñado junto a gerentes reales
          </h3>
          <p class="text-[#1A3C34] text-center text-sm">
            Desarrollado con profesionales de la hostelería para adaptarse a tus necesidades reales.
          </p>
        </div>

        <!-- Card 3: Impulsado por IA -->
        <div class="bg-[#FFFFFF] rounded-xl p-6 shadow-lg">
          <div class="flex justify-center mb-4">
            <svg
              class="w-12 h-12 text-[#6B9E86]"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-[#1A3C34] mb-3 text-center">
            Impulsado por IA
          </h3>
          <p class="text-[#1A3C34] text-center text-sm">
            Tecnología de inteligencia artificial que aprende y mejora con cada interacción.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
