---

---

<section id="features" class="pt-12 pb-12 bg-[#6B9E86]">
  <div class="container mx-auto px-6">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-10">
      <h2 class="text-3xl md:text-5xl font-bold text-white mb-6">
        Características que <br />
        <span class="text-[#000000]">
          transforman
        </span> tu negocio
      </h2>
      <p class="text-lg md:text-xl text-white mb-8">
        Descubre cómo nuestra tecnología optimiza cada rincón de tu negocio.
        Maingoo tiene herramientas diseñadas para ahorrar tiempo, reducir costes
        y maximizar beneficios.
      </p>
      <div class="flex justify-center mb-8">
        <button
          data-open-chat
          class="relative bg-transparent text-[#000000] px-6 sm:px-8 py-4 rounded-lg text-base sm:text-lg font-semibold hover:shadow-xl transition-all transform hover:-translate-y-1 inline-flex items-center justify-center gap-2"
          style="border: 3px solid #6B9E86; background-image: linear-gradient(#F0F7F4, #F0F7F4),  background-origin: border-box; background-clip: padding-box, border-box;"
        >
          <img src="/maingoo_logo.svg" alt="IA" class="w-7 h-7" />
          Pregunta a Maingoo
        </button>
      </div>
    </div>

    <!-- Grid de Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      <!-- Card 1 - Carga Automática -->
      <button
      class="group bg-white rounded-2xl sm:rounded-3xl p-6 sm:p-8 shadow-lg hover:-translate-y-1 hover:shadow-xl transition-all duration-300 text-left w-full cursor-pointer"
        data-feature="1"
      >
        <!-- Icono -->
        <div
          class="w-14 h-14 bg-gray-100 group-hover:bg-[#6B9E86] rounded-2xl flex items-center justify-center mb-5 transition-colors duration-300"
        >
          <svg
            class="w-7 h-7 text-gray-900 group-hover:text-white transition-colors duration-300"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"
            ></path>
          </svg>
        </div>

        <h3 class="text-xl font-semibold text-gray-900 mb-3">
          Carga Automática
        </h3>
        <p class="text-sm text-gray-500 leading-relaxed mb-6">
          Olvídate de teclear. Sube facturas y albaranes y la IA los procesa en
          segundos.
        </p>

        <!-- Botón Ver detalles -->
        <div
          class="inline-flex items-center gap-2 text-[#0f3930] group-hover:text-[#0a2620] font-medium text-sm transition-colors min-h-[44px] py-2"
        >
          Ver detalles
          <svg
            class="w-4 h-4 transition-transform group-hover:translate-x-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 5l7 7-7 7"></path>
          </svg>
        </div>
      </button>

      <!-- Card 2 - Análisis Predictivo -->
      <button
        class="group bg-white rounded-2xl sm:rounded-3xl p-6 sm:p-8 shadow-lg hover:-translate-y-1 hover:shadow-xl transition-all duration-300 text-left w-full cursor-pointer"
        data-feature="2"
      >
        <!-- Icono -->
        <div
          class="w-14 h-14 bg-gray-100 group-hover:bg-[#6B9E86] rounded-2xl flex items-center justify-center mb-5 transition-colors duration-300"
        >
          <svg
            class="w-7 h-7 text-gray-900 group-hover:text-white transition-colors duration-300"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
          </svg>
        </div>

        <h3 class="text-xl font-semibold text-gray-900 mb-3">
          Análisis Predictivo
        </h3>
        <p class="text-sm text-gray-500 leading-relaxed mb-6">
          Anticípate al futuro. Ajusta stock y personal basándote en
          predicciones reales.
        </p>

        <!-- Botón Ver detalles -->
        <div
          class="inline-flex items-center gap-2 text-[#0f3930] group-hover:text-[#0a2620] font-medium text-sm transition-colors min-h-[44px] py-2"
        >
          Ver detalles
          <svg
            class="w-4 h-4 transition-transform group-hover:translate-x-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 5l7 7-7 7"></path>
          </svg>
        </div>
      </button>

      <!-- Card 3 - Inventario Inteligente -->
      <button
        class="group bg-white rounded-2xl sm:rounded-3xl p-6 sm:p-8 shadow-lg hover:-translate-y-1 hover:shadow-xl transition-all duration-300 text-left w-full cursor-pointer"
        data-feature="3"
      >
        <!-- Icono -->
        <div
          class="w-14 h-14 bg-gray-100 group-hover:bg-[#6B9E86] rounded-2xl flex items-center justify-center mb-5 transition-colors duration-300"
        >
          <svg
            class="w-7 h-7 text-gray-900 group-hover:text-white transition-colors duration-300"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"
            ></path>
          </svg>
        </div>

        <h3 class="text-xl font-semibold text-gray-900 mb-3">
          Inventario Inteligente
        </h3>
        <p class="text-sm text-gray-500 leading-relaxed mb-6">
          Control total. El sistema descuenta stock al vender y sugiere pedidos.
        </p>

        <!-- Botón Ver detalles -->
        <div
          class="inline-flex items-center gap-2 text-[#0f3930] group-hover:text-[#0a2620] font-medium text-sm transition-colors min-h-[44px] py-2"
        >
          Ver detalles
          <svg
            class="w-4 h-4 transition-transform group-hover:translate-x-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 5l7 7-7 7"></path>
          </svg>
        </div>
      </button>

      <!-- Card 4 - Maingoo IA -->
      <button
        class="group bg-white rounded-2xl sm:rounded-3xl p-6 sm:p-8 shadow-lg hover:-translate-y-1 hover:shadow-xl transition-all duration-300 text-left w-full cursor-pointer"
        data-feature="4"
      >
        <!-- Icono Dark Mode para IA -->
        <div
          class="w-14 h-14 bg-gray-100 group-hover:bg-[#6B9E86] rounded-2xl flex items-center justify-center mb-5 transition-colors duration-300"
        >
          <svg
            class="w-7 h-7 text-gray-900 group-hover:text-white transition-colors duration-300"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z"
            ></path>
          </svg>
        </div>

        <h3 class="text-xl font-semibold text-gray-900 mb-3">Maingoo IA</h3>
        <p class="text-sm text-gray-500 leading-relaxed mb-6">
          Tu consultor 24/7. Pregunta lo que quieras y obtén respuestas al
          instante.
        </p>

        <!-- Botón Ver detalles -->
        <div
          class="inline-flex items-center gap-2 text-[#0f3930] group-hover:text-[#0a2620] font-medium text-sm transition-colors min-h-[44px] py-2"
        >
          Ver detalles
          <svg
            class="w-4 h-4 transition-transform group-hover:translate-x-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 5l7 7-7 7"></path>
          </svg>
        </div>
      </button>

      <!-- Card 5 - Optimización de Costes -->
      <button
        class="group bg-white rounded-2xl sm:rounded-3xl p-6 sm:p-8 shadow-lg hover:-translate-y-1 hover:shadow-xl transition-all duration-300 text-left w-full cursor-pointer"
        data-feature="5"
      >
        <!-- Icono -->
        <div
          class="w-14 h-14 bg-gray-100 group-hover:bg-[#6B9E86] rounded-2xl flex items-center justify-center mb-5 transition-colors duration-300"
        >
          <svg
            class="w-7 h-7 text-gray-900 group-hover:text-white transition-colors duration-300"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"
            ></path>
          </svg>
        </div>

        <h3 class="text-xl font-semibold text-gray-900 mb-3">
          Optimización de Costes
        </h3>
        <p class="text-sm text-gray-500 leading-relaxed mb-6">
          Detecta fugas de dinero y compara precios de proveedores
          automáticamente.
        </p>

        <!-- Botón Ver detalles -->
        <div
          class="inline-flex items-center gap-2 text-[#0f3930] group-hover:text-[#0a2620] font-medium text-sm transition-colors min-h-[44px] py-2"
        >
          Ver detalles
          <svg
            class="w-4 h-4 transition-transform group-hover:translate-x-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 5l7 7-7 7"></path>
          </svg>
        </div>
      </button>

      <!-- Card 6 - Integración Total -->
      <button
        class="group bg-white rounded-2xl sm:rounded-3xl p-6 sm:p-8 shadow-lg hover:-translate-y-1 hover:shadow-xl transition-all duration-300 text-left w-full cursor-pointer"
        data-feature="6"
      >
        <!-- Icono -->
        <div
          class="w-14 h-14 bg-gray-100 group-hover:bg-[#6B9E86] rounded-2xl flex items-center justify-center mb-5 transition-colors duration-300"
        >
          <svg
            class="w-7 h-7 text-gray-900 group-hover:text-white transition-colors duration-300"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"
            ></path>
          </svg>
        </div>

        <h3 class="text-xl font-semibold text-gray-900 mb-3">
          Integración Total
        </h3>
        <p class="text-sm text-gray-500 leading-relaxed mb-6">
          Todo conectado: TPV, delivery, horarios y facturación en un solo
          lugar.
        </p>

        <!-- Botón Ver detalles -->
        <div
          class="inline-flex items-center gap-2 text-[#0f3930] group-hover:text-[#0a2620] font-medium text-sm transition-colors min-h-[44px] py-2"
        >
          Ver detalles
          <svg
            class="w-4 h-4 transition-transform group-hover:translate-x-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 5l7 7-7 7"></path>
          </svg>
        </div>
      </button>
    </div>
  </div>

  <!-- Modal -->
  <div id="feature-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
    <!-- Backdrop -->
    <div
      class="fixed inset-0 bg-black/60 backdrop-blur-sm transition-opacity"
      id="modal-backdrop"
    >
    </div>

    <!-- Modal Container -->
    <div class="flex min-h-screen items-end sm:items-center justify-center p-0 sm:p-4">
      <div
        class="relative bg-white rounded-t-2xl sm:rounded-3xl shadow-2xl max-w-5xl w-full sm:mx-4 overflow-hidden max-h-[92vh] sm:max-h-[90vh] overflow-y-auto"
      >
        <!-- Grid Layout: 2 columnas en desktop, 1 en móvil -->
        <div class="grid grid-cols-1 lg:grid-cols-2">
          <!-- Columna Izquierda: Media/Demo -->
          <div
            class="relative h-44 sm:h-64 lg:h-auto lg:min-h-full bg-gray-100 flex items-center justify-center"
          >
            <img
              src="/maingo_origin.png"
              alt="Vista previa de Maingoo"
              class="w-full h-full object-cover"
            />

            <!-- Play Button Overlay -->
            <div class="absolute inset-0 flex items-center justify-center">
              <button
                class="w-16 h-16 bg-white rounded-full shadow-lg flex items-center justify-center hover:scale-110 transition-transform"
              >
                <svg
                  class="w-8 h-8 text-[#6B9E86] ml-1"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path d="M8 5v14l11-7z"></path>
                </svg>
              </button>
            </div>
          </div>

          <!-- Columna Derecha: Contenido -->
          <div class="p-5 sm:p-8 lg:p-10 relative flex flex-col">
            <!-- Botón Cerrar -->
            <button
              id="close-modal"
              class="absolute top-4 right-4 min-h-11 min-w-11 flex items-center justify-center rounded-full bg-white/90 hover:bg-gray-100 transition-colors z-10"
              aria-label="Cerrar detalles"
            >
              <svg
                class="w-5 h-5 text-gray-600"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>

            <!-- Badge -->
            <div class="inline-block mb-4">
              <span
                class="bg-[#6B9E86]/10 text-[#6B9E86] text-xs font-bold rounded-full px-3 py-1"
                >NOVEDAD</span
              >
            </div>

            <!-- Título -->
            <h2 id="modal-title" class="text-2xl lg:text-3xl font-bold text-gray-900 mb-4">
              Integración Total
            </h2>

            <!-- Descripción -->
            <p id="modal-description" class="text-gray-600 leading-relaxed mb-6 text-sm lg:text-base">
              Se acabó la fragmentación. Maingoo centraliza TPV, apps de
              delivery (Glovo, Uber) y gestión de personal en una única
              plataforma inteligente que sincroniza todo en tiempo real.
            </p>

            <!-- Beneficios Clave -->
            <div class="bg-[#6B9E86]/5 rounded-2xl p-4 sm:p-6">
              <div class="flex items-center gap-2 mb-4">
                <svg
                  class="w-5 h-5 text-[#6B9E86]"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 13l4 4L19 7"></path>
                </svg>
                <h3
                  class="text-xs font-bold text-gray-900 uppercase tracking-wide"
                >
                  Beneficios Clave
                </h3>
              </div>

              <ul id="modal-benefits" class="space-y-3">
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Data de las features
    const featuresData = {
      "1": {
        title: "Carga Automática de Facturas",
        description: "Nuestro sistema de análisis de documentos con IA extrae automáticamente toda la información de tus facturas y albaranes: fechas, importes, impuestos y conceptos clave. Todo queda digitalizado y organizado al instante.",
        benefits: [
          "Reconocimiento automático de proveedores",
          "Validación automática de importes",
          "Detección de duplicados",
          "Archivo digital organizado y seguro",
          "Clasificación automática de productos y categorías",
          "Integración directa con inventario y costes"
        ]
      },
      "2": {
        title: "Análisis Predictivo",
        description: "Nuestra IA aprende de tu negocio y te da predicciones claras sobre ventas, temporadas y consumo. Podrás saber qué se venderá más, cuándo pedir y cómo evitar quedarte corto o con exceso de stock.",
        benefits: [
          "Predicción de ventas por temporada",
          "Optimización de niveles de stock",
          "Identificación de patrones de compra",
          "Recomendaciones personalizadas",
          "Alertas de picos de demanda",
          "Sugerencias de ofertas y promociones"
        ]
      },
      "3": {
        title: "Inventario Inteligente",
        description: "Mantén un control total sobre tu inventario con actualizaciones en tiempo real y gestión automatizada. El sistema aprende de tus patrones de venta para sugerir pedidos óptimos y prevenir roturas de stock.",
        benefits: [
          "Monitorización en tiempo real",
          "Alertas de stock bajo",
          "Sugerencias de reposición",
          "Gestión multi-almacén integrada",
          "Control de caducidades y mermas",
          "Actualización automática tras ventas y recepciones"
        ]
      },
      "4": {
        title: "Maingoo IA",
        description: "Maingoo incluye un chat integrado que entiende tus preguntas en lenguaje natural. Puedes pedir cifras, comparativas o explicaciones y el sistema responde con claridad, gráficos o recomendaciones prácticas. Toma decisiones rápidas con informes automáticos y fáciles de entender.",
        benefits: [
          "Respuestas inmediatas en lenguaje natural",
          "Métricas clave de rendimiento",
          "Dashboards interactivos",
          "Informes programados automáticos o bajo demanda",
          "Interacción accesible desde cualquier módulo de la app",
          "Recomendaciones prácticas basadas en tus datos"
        ]
      },
      "5": {
        title: "Optimización de Costes",
        description: "Identifica y aprovecha oportunidades de ahorro con nuestro sistema de optimización de costes. Analiza gastos, compara proveedores y maximiza tus márgenes de beneficio de forma inteligente.",
        benefits: [
          "Análisis de gastos por categoría",
          "Detección de gastos innecesarios",
          "Comparativa automática de proveedores",
          "Alertas de variaciones de precio",
          "Sugerencias de ahorro personalizadas",
          "Informes de rentabilidad por producto"
        ]
      },
      "6": {
        title: "Integración Total",
        description: "Se acabó la fragmentación. Maingoo centraliza TPV, apps de delivery (Glovo, Uber) y gestión de personal en una única plataforma inteligente que sincroniza todo en tiempo real.",
        benefits: [
          "Conexión nativa con TPV",
          "Integración Delivery",
          "Sincronización contable",
          "Gestión de personal integrada"
        ]
      }
    };

    // Funcionalidad del modal
    const modal = document.getElementById("feature-modal");
    const modalBackdrop = document.getElementById("modal-backdrop");
    const closeModalBtn = document.getElementById("close-modal");
    const featureCards = document.querySelectorAll("button[data-feature]");
    const modalTitle = document.getElementById("modal-title");
    const modalDescription = document.getElementById("modal-description");
    const modalBenefits = document.getElementById("modal-benefits");

    // Abrir modal al hacer clic en cualquier card
    featureCards.forEach((card) => {
      card.addEventListener("click", () => {
        const featureId = card.getAttribute("data-feature");
        if (!featureId) return;
        
        const featureData = featuresData[featureId as keyof typeof featuresData];
        
        if (featureData && modalTitle && modalDescription && modalBenefits) {
          // Actualizar contenido del modal
          modalTitle.textContent = featureData.title;
          modalDescription.textContent = featureData.description;
          
          // Actualizar beneficios
          modalBenefits.innerHTML = featureData.benefits.map((benefit: string) => `
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 rounded-full bg-emerald-500 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                </svg>
              </div>
              <span class="text-sm text-gray-700">${benefit}</span>
            </li>
          `).join('');
        }
        
        modal?.classList.remove("hidden");
        document.body.style.overflow = "hidden";
      });
    });

    // Cerrar modal
    const closeModal = () => {
      modal?.classList.add("hidden");
      document.body.style.overflow = "";
    };

    closeModalBtn?.addEventListener("click", closeModal);
    modalBackdrop?.addEventListener("click", closeModal);

    // Cerrar con ESC
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !modal?.classList.contains("hidden")) {
        closeModal();
      }
    });
  </script>
</section>
