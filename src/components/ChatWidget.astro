---

---

<!-- Chat Widget -->
<div id="chat-widget" class="fixed bottom-6 right-6 z-50">
  <!-- Botón Burbuja Flotante -->
  <button
    id="chat-toggle"
    class="w-16 h-16 bg-[#6B9E86] hover:bg-[#5a8a71] text-white rounded-full shadow-lg hover:shadow-2xl transition-all duration-300 flex items-center justify-center hover:scale-110"
    aria-label="Abrir chat de Maingoo IA"
  >
    <img src="/maingoo_logo.svg" alt="Chat IA" class="w-8 h-8" />
  </button>

  <!-- Chat Window -->
  <div
    id="chat-window"
    class="absolute bottom-20 right-0 w-80 h-[480px] bg-[#F0F7F4] rounded-lg shadow-2xl border border-[#6B9E86]/30 transform origin-bottom-right scale-0 opacity-0 transition-all duration-300 overflow-hidden backdrop-blur-sm"
  >
    <!-- Chat Header -->
    <div
      class="bg-[#1A3C34] text-white p-4 rounded-t-lg"
    >
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <div class="w-8 h-8 rounded-full flex items-center justify-center">
            <img
              src="/maingoo_logo.svg"
              alt="Maingoo Logo"
              class="h-8 w-8 sm:h-10 sm:w-10 lg:h-12 lg:w-12 object-contain"
            />
          </div>
          <div>
            <h3 class="font-semibold text-sm">Maingoo</h3>
            <div class="flex items-center space-x-1 text-xs opacity-90">
              <div class="w-2 h-2 bg-[#6B9E86] rounded-full"></div>
              <span>En línea</span>
            </div>
          </div>
        </div>
        <button
          id="minimize-chat"
          class="p-1 hover:bg-white/20 rounded transition-colors"
          aria-label="Minimizar chat"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M20 12H4"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Chat Messages -->
    <div
      id="chat-messages"
      class="flex-1 p-4 space-y-3 overflow-y-auto h-80 bg-[#F0F7F4]"
    >
      <!-- Welcome Message -->
      <div class="flex items-start space-x-2">
        <div
          class="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0"
        >
          <img
            src="/maingoo_logo.svg"
            alt="Maingoo Logo"
            class="h-8 w-8 sm:h-10 sm:w-10 lg:h-12 lg:w-12 object-contain"
          />
        </div>
        <div
          class="bg-white rounded-lg p-3 shadow-sm max-w-xs border border-[#6B9E86]/20"
        >
          <p class="text-sm text-[#1A3C34]">
            Hola 👋 Soy Maingoo. Antes de continuar, te animo a écharle un
            vistazo al apartado de <a href="#features" class="text-[#1A3C34] underline decoration-[#1A3C34] hover:decoration-[#6B9E86] transition-colors">Características</a> de la web, allí verás todo lo
            que ofrecemos. Y si te surge cualquier duda, pregúntame por este
            chat.
          </p>
          <span class="text-xs text-[#6B9E86] mt-1 block"
            >Ahora</span
          >
        </div>
      </div>
    </div>

    <!-- Chat Input -->
    <div
      class="p-4 border-t border-[#6B9E86]/30 bg-white rounded-b-lg"
    >
      <div class="flex space-x-2">
        <input
          type="text"
          id="chat-input"
          placeholder="Escribe tu mensaje..."
          class="flex-1 px-3 py-2 border border-[#6B9E86]/40 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#6B9E86] bg-white text-[#1A3C34] placeholder-[#6B9E86]/60 text-sm transition-all duration-300"
        />
        <button
          id="send-message"
          class="bg-[#1A3C34] hover:bg-[#6B9E86] text-white px-4 py-2 rounded-lg transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
          </svg>
        </button>
      </div>
      <p id="chat-status" class="text-xs text-[#6B9E86] mt-2 text-center">
        IA local en Chrome
      </p>
    </div>
  </div>
</div>

<script is:inline>
  class ChatWidget {
    constructor() {
      this.isOpen = false;
      this.aiSession = null;
      this.aiSessionPromise = null;
      this.aiOptions = {
        expectedInputs: [{ type: "text", languages: ["es"] }],
        expectedOutputs: [{ type: "text", languages: ["es"] }],
      };
      this.systemPrompt = `
Eres Maingoo, el asistente local de la landing de Maingoo.
Responde siempre en español, con tono cercano, claro y profesional.
Tu objetivo es ayudar a restaurantes, bares, cafeterías y negocios hosteleros a entender Maingoo.

Contexto de producto:
- Maingoo es una herramienta de gestión inteligente para restaurantes con IA.
- La landing presenta funcionalidades como carga automática de facturas y albaranes, análisis predictivo, inventario inteligente, optimización de costes, gestión de proveedores, panel de control, analíticas y futuras integraciones con TPV, delivery, APPCC, recetas, escandallos y RRHH.
- Actualmente se ofrece acceso gratuito a una beta temprana.
- Para solicitar acceso, recomienda usar el formulario de contacto de la web.

Reglas:
- No inventes precios definitivos, fechas de lanzamiento ni condiciones legales.
- Si no sabes algo, dilo con honestidad y sugiere dejar datos en el formulario.
- Si la pregunta no trata de Maingoo o gestión hostelera, responde brevemente y redirige a cómo Maingoo puede ayudar.
- Mantén respuestas breves, útiles y fáciles de leer.
`.trim();

      // Inicializar cuando el DOM esté listo
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", () =>
          this.initializeElements()
        );
      } else {
        this.initializeElements();
      }
    }

    initializeElements() {
      this.chatWindow = document.getElementById("chat-window");
      this.chatToggle = document.getElementById("chat-toggle");
      this.minimizeChat = document.getElementById("minimize-chat");
      this.chatInput = document.getElementById("chat-input");
      this.sendButton = document.getElementById("send-message");
      this.chatMessages = document.getElementById("chat-messages");
      this.chatStatus = document.getElementById("chat-status");

      // Bindear eventos
      if (this.chatToggle) {
        this.chatToggle.addEventListener("click", () => this.openChat());
      }
      if (this.minimizeChat) {
        this.minimizeChat.addEventListener("click", () => this.closeChat());
      }
      if (this.sendButton) {
        this.sendButton.addEventListener("click", () => this.sendMessage());
      }
      if (this.chatInput) {
        this.chatInput.addEventListener("keypress", (e) => {
          if (e.key === "Enter" && !e.shiftKey) {
            e.preventDefault();
            this.sendMessage();
          }
        });
        this.chatInput.addEventListener("input", () => {
          this.sendButton.disabled = !this.chatInput.value.trim();
        });
      }

      this.checkLocalAiAvailability();
    }

    openChat() {
      if (!this.chatWindow) return;

      this.isOpen = true;

      // Mostrar la ventana del chat
      requestAnimationFrame(() => {
        this.chatWindow.style.transform = "scale(1)";
        this.chatWindow.style.opacity = "1";
      });

      // Focus input después de la animación
      setTimeout(() => {
        if (this.chatInput) {
          this.chatInput.focus();
        }
      }, 300);
    }

    closeChat() {
      if (!this.chatWindow) return;

      this.isOpen = false;

      // Ocultar la ventana del chat
      requestAnimationFrame(() => {
        this.chatWindow.style.transform = "scale(0)";
        this.chatWindow.style.opacity = "0";
      });
    }

    async sendMessage() {
      const message = this.chatInput.value.trim();
      if (!message) return;

      // Add user message to chat
      this.addMessage(message, "user");

      // Clear input
      this.chatInput.value = "";
      this.sendButton.disabled = true;

      // Show typing indicator
      this.showTypingIndicator();

      try {
        const session = await this.getLocalAiSession();
        this.hideTypingIndicator();

        const botMessage = this.addStreamingBotMessage();
        let responseText = "";
        const stream = session.promptStreaming(message);

        for await (const chunk of stream) {
          responseText += chunk;
          botMessage.textElement.textContent = responseText;
          this.scrollToBottom();
        }

        if (!responseText.trim()) {
          botMessage.textElement.textContent =
            "No he podido generar una respuesta clara. Puedes dejar tus datos en el formulario y el equipo de Maingoo te ayudará.";
        }

        this.updateStatus("IA local lista");
        this.sendButton.disabled = false;
      } catch (error) {
        this.hideTypingIndicator();
        this.addMessage(this.getLocalAiErrorMessage(error), "bot");
        this.updateStatus("IA local no disponible");
        this.sendButton.disabled = false;
      }
    }

    async checkLocalAiAvailability() {
      const languageModel = window.LanguageModel;

      if (!languageModel?.availability) {
        this.updateStatus("IA local no disponible en este navegador");
        return;
      }

      try {
        const availability = await languageModel.availability(this.aiOptions);

        if (availability === "available") {
          this.updateStatus("IA local lista");
        } else if (availability === "downloadable") {
          this.updateStatus("IA local pendiente de descarga");
        } else if (availability === "downloading") {
          this.updateStatus("Descargando IA local");
        } else {
          this.updateStatus("IA local no disponible");
        }
      } catch (error) {
        this.updateStatus("IA local no disponible");
      }
    }

    async getLocalAiSession() {
      if (this.aiSession) {
        return this.aiSession;
      }

      if (!this.aiSessionPromise) {
        this.aiSessionPromise = this.createLocalAiSession();
      }

      this.aiSession = await this.aiSessionPromise;
      return this.aiSession;
    }

    async createLocalAiSession() {
      const languageModel = window.LanguageModel;

      if (!languageModel?.availability || !languageModel?.create) {
        throw new Error("prompt-api-unavailable");
      }

      const availability = await languageModel.availability(this.aiOptions);

      if (availability === "unavailable") {
        throw new Error("prompt-api-unavailable");
      }

      if (availability === "downloadable" || availability === "downloading") {
        this.updateStatus("Preparando IA local");
      }

      return languageModel.create({
        ...this.aiOptions,
        initialPrompts: [{ role: "system", content: this.systemPrompt }],
        monitor: (monitor) => {
          monitor.addEventListener("downloadprogress", (event) => {
            const progress = Math.round(event.loaded * 100);
            this.updateStatus(`Descargando IA local ${progress}%`);
          });
        },
      });
    }

    addMessage(message, sender) {
      const messageDiv = document.createElement("div");
      messageDiv.className = "flex items-start space-x-2";

      const isUser = sender === "user";

      if (isUser) {
        messageDiv.className += " justify-end";
        messageDiv.innerHTML = `
          <div class="bg-[#1A3C34] text-white rounded-lg p-3 shadow-sm max-w-xs">
            <p class="text-sm">${this.escapeHtml(message)}</p>
            <span class="text-xs opacity-75 mt-1 block">Ahora</span>
          </div>
          <div class="w-6 h-6 bg-[#6B9E86] rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path>
            </svg>
          </div>
        `;
      } else {
        messageDiv.innerHTML = `
          <div class="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0">
            <img
              src="/maingoo_logo.svg"
              alt="Maingoo Logo"
              class="h-6 w-6 object-contain"
            />
          </div>
          <div class="bg-white rounded-lg p-3 shadow-sm max-w-xs border border-[#6B9E86]/20">
            <p class="text-sm text-[#1A3C34]">${this.escapeHtml(message)}</p>
            <span class="text-xs text-[#6B9E86] mt-1 block">Ahora</span>
          </div>
        `;
      }

      this.chatMessages.appendChild(messageDiv);
      this.scrollToBottom();
    }

    addStreamingBotMessage() {
      const messageDiv = document.createElement("div");
      messageDiv.className = "flex items-start space-x-2";
      messageDiv.innerHTML = `
        <div class="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0">
          <img
            src="/maingoo_logo.svg"
            alt="Maingoo Logo"
            class="h-6 w-6 object-contain"
          />
        </div>
        <div class="bg-white rounded-lg p-3 shadow-sm max-w-xs border border-[#6B9E86]/20">
          <p class="text-sm text-[#1A3C34]"></p>
          <span class="text-xs text-[#6B9E86] mt-1 block">Ahora</span>
        </div>
      `;

      const textElement = messageDiv.querySelector("p");
      this.chatMessages.appendChild(messageDiv);
      this.scrollToBottom();

      return { messageDiv, textElement };
    }

    showTypingIndicator() {
      const typingDiv = document.createElement("div");
      typingDiv.id = "typing-indicator";
      typingDiv.className = "flex items-start space-x-2";
      typingDiv.innerHTML = `
        <div class="w-6 h-6  rounded-full flex items-center justify-center flex-shrink-0">
          <img
              src="/maingoo_logo.svg"
              alt="Maingoo Logo"
              class="h-8 w-8 sm:h-10 sm:w-10 lg:h-12 lg:w-12 object-contain"
            />
        </div>
        <div class="bg-white rounded-lg p-3 shadow-sm border border-[#6B9E86]/20">
          <div class="flex space-x-1">
            <div class="w-2 h-2 bg-[#6B9E86] rounded-full animate-bounce"></div>
            <div class="w-2 h-2 bg-[#6B9E86] rounded-full animate-bounce" style="animation-delay: 0.1s"></div>
            <div class="w-2 h-2 bg-[#6B9E86] rounded-full animate-bounce" style="animation-delay: 0.2s"></div>
          </div>
        </div>
      `;

      this.chatMessages.appendChild(typingDiv);
      this.scrollToBottom();
    }

    hideTypingIndicator() {
      const typingIndicator = document.getElementById("typing-indicator");
      if (typingIndicator) {
        typingIndicator.remove();
      }
    }

    scrollToBottom() {
      this.chatMessages.scrollTop = this.chatMessages.scrollHeight;
    }

    escapeHtml(text) {
      const map = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#039;",
      };
      return text.replace(/[&<>"']/g, (m) => map[m]);
    }

    updateStatus(status) {
      if (this.chatStatus) {
        this.chatStatus.textContent = status;
      }
    }

    getLocalAiErrorMessage(error) {
      if (error?.name === "NotSupportedError") {
        return "La IA local de Chrome no soporta esta configuración en tu dispositivo. Puedes usar el formulario de contacto y el equipo de Maingoo te ayudará.";
      }

      if (error?.name === "QuotaExceededError") {
        return "La conversación se ha hecho demasiado larga para la IA local. Cierra y vuelve a abrir el chat para empezar de nuevo.";
      }

      return "Este chat usa la IA local de Chrome y ahora mismo no está disponible en tu navegador o dispositivo. Puedes dejar tus datos en el formulario de contacto y el equipo de Maingoo te ayudará.";
    }
  }

  // Initialize chat widget immediately
  window.ChatWidget = ChatWidget;
  window.chatWidget = new ChatWidget();
</script>

<style>
  /* Custom scrollbar for chat messages */
  #chat-messages::-webkit-scrollbar {
    width: 4px;
  }

  #chat-messages::-webkit-scrollbar-track {
    background: transparent;
  }

  #chat-messages::-webkit-scrollbar-thumb {
    background: #6B9E86;
    border-radius: 2px;
  }

  #chat-messages::-webkit-scrollbar-thumb:hover {
    background: #1A3C34;
  }

  /* Animation for smooth transitions */
  #chat-window {
    transform-origin: bottom right;
  }

  /* Bounce animation keyframes */
  @keyframes bounce {
    0%,
    20%,
    53%,
    80%,
    100% {
      transform: translate3d(0, 0, 0);
    }
    40%,
    43% {
      transform: translate3d(0, -30px, 0);
    }
    70% {
      transform: translate3d(0, -15px, 0);
    }
    90% {
      transform: translate3d(0, -4px, 0);
    }
  }
</style>

<script>
  // Script adicional para conectar botones "open-chat" en otros componentes
  document.addEventListener("DOMContentLoaded", () => {
    const openChatButtons = document.querySelectorAll("#open-chat");
    
    openChatButtons.forEach(button => {
      button.addEventListener("click", (e) => {
        e.preventDefault();
        
        // Activar el botón toggle del chat
        const chatToggle = document.getElementById("chat-toggle");
        if (chatToggle) {
          chatToggle.click();
        }
      });
    });
  });
</script>
