---

---

<header
  class="fixed top-0 w-full z-50 border-gray-100 dark:border-gray-800"
  style="background-color: #6B9E86;"
>
  <nav class="container mx-auto px-4 sm:px-6 lg:px-8 py-3 sm:py-4 lg:py-5">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <div class="flex items-center space-x-2">
        <img
          src="/maingoo_logo.svg"
          alt="Maingoo Logo"
          class="h-10 w-10 sm:h-12 sm:w-12 lg:h-16 lg:w-16 object-contain"
        />
        <a
          href="/"
          class="text-[32px] font-semibold dark:text-black transition-colors"
          style="--hover-color: #F0F7F4;">Maingoo</a
        >
      </div>

      <!-- Navigation Links -->
      <div class="hidden lg:flex items-center space-x-10 xl:space-x-12">
        <a
          href="/#features"
          class="text-[16px] font-normal dark:text-[#000000] transition-colors whitespace-nowrap"
          style="--hover-color: #F0F7F4;"
          onmouseover="this.style.color='#F0F7F4'"
          onmouseout="this.style.color=''">Características</a
        >
        <a
          href="/#pricing"
          class="text-[16px] font-normal dark:text-[#000000] transition-colors whitespace-nowrap"
          style="--hover-color: #F0F7F4;"
          onmouseover="this.style.color='#F0F7F4'"
          onmouseout="this.style.color=''">Precios</a
        >
        <a
          href="/#contact"
          class="text-[16px] font-normal dark:text-[#000000] transition-colors whitespace-nowrap"
          style="--hover-color: #F0F7F4;"
          onmouseover="this.style.color='#F0F7F4'"
          onmouseout="this.style.color=''">Contacto</a
        >
        <a
          href="/#faqs"
          class="text-[16px] font-normal dark:text-[#000000] transition-colors whitespace-nowrap"
          style="--hover-color: #F0F7F4;"
          onmouseover="this.style.color='#F0F7F4'"
          onmouseout="this.style.color=''">FAQs</a
        >
      </div>

      <!-- Dark Mode Toggle & CTA Buttons -->
      <div class="flex items-center space-x-2 sm:space-x-3 lg:space-x-4">
        <a
          href="https://app.maingoo.tech/"
          class="hidden lg:block text-[16px] font-normal dark:text-[#000000] transition-colors"
          style="--hover-color: #F0F7F4;"
          onmouseover="this.style.color='#F0F7F4'"
          onmouseout="this.style.color=''"
        >
          Iniciar Sesión
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button class="lg:hidden p-2 dark:text-[#000000]" id="mobile-menu-button">
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div
      id="mobile-menu"
      class="lg:hidden hidden dark:bg-[#6B9E86] backdrop-blur-md border-t dark:border-gray-800"
    >
      <div class="px-4 py-4 space-y-4">
        <a
          href="/#contact"
          class="block text-[16px] font-normal text-gray-600 dark:text-[#000000] transition-colors py-2"
          style="--hover-color: #6B9E86;"
          onmouseover="this.style.color='#6B9E86'"
          onmouseout="this.style.color=''">Contacto</a
        >
        <a
          href="/#features"
          class="block text-[16px] font-normal text-gray-600 dark:text-[#000000] transition-colors py-2"
          style="--hover-color: #6B9E86;"
          onmouseover="this.style.color='#6B9E86'"
          onmouseout="this.style.color=''">Características</a
        >
        <a
          href="/#pricing"
          class="block text-[16px] font-normal text-gray-600 dark:text-[#000000] transition-colors py-2"
          style="--hover-color: #6B9E86;"
          onmouseover="this.style.color='#6B9E86'"
          onmouseout="this.style.color=''">Precios</a
        >
        <div class="pt-4 border-t border-gray-200 dark:border-gray-700">
          <a
            href="https://app.maingoo.tech/"
            class="block w-full text-left text-[16px] font-normal text-gray-600 dark:text-[#000000] transition-colors py-2"
            style="--hover-color: #6B9E86;"
            onmouseover="this.style.color='#6B9E86'"
            onmouseout="this.style.color=''"
          >
            Iniciar Sesión
          </a>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    function applyDarkMode(isDark: boolean) {
      const htmlElement = document.documentElement;

      if (isDark) {
        htmlElement.classList.add("dark");
      }
    }

    applyDarkMode(true);

    // Mobile Menu Functionality
    const mobileMenuButton = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");

    if (mobileMenuButton && mobileMenu) {
      mobileMenuButton.addEventListener("click", () => {
        // Toggle mobile menu visibility
        mobileMenu.classList.toggle("hidden");

        // Change hamburger icon to X when menu is open
        const svg = mobileMenuButton.querySelector("svg");
        if (svg) {
          const path = svg.querySelector("path");
          if (path) {
            if (mobileMenu.classList.contains("hidden")) {
              // Hamburger icon
              path.setAttribute("d", "M4 6h16M4 12h16M4 18h16");
            } else {
              // X icon
              path.setAttribute("d", "M6 18L18 6M6 6l12 12");
            }
          }
        }
      });

      // Close menu when clicking on links
      const mobileMenuLinks = mobileMenu.querySelectorAll("a");
      mobileMenuLinks.forEach((link) => {
        link.addEventListener("click", () => {
          mobileMenu.classList.add("hidden");
          // Reset to hamburger icon
          const svg = mobileMenuButton.querySelector("svg");
          if (svg) {
            const path = svg.querySelector("path");
            if (path) {
              path.setAttribute("d", "M4 6h16M4 12h16M4 18h16");
            }
          }
        });
      });

      // Close menu when clicking outside
      document.addEventListener("click", (event) => {
        const target = event.target as Node;
        if (
          target &&
          !mobileMenuButton.contains(target) &&
          !mobileMenu.contains(target)
        ) {
          mobileMenu.classList.add("hidden");
          // Reset to hamburger icon
          const svg = mobileMenuButton.querySelector("svg");
          if (svg) {
            const path = svg.querySelector("path");
            if (path) {
              path.setAttribute("d", "M4 6h16M4 12h16M4 18h16");
            }
          }
        }
      });
    }
  });
</script>
